      "title": "RAG 총 요청 수",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rag_requests_total",
          "legendFormat": "RAG 요청",
          "refId": "A"
        }
